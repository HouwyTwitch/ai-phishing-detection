# АнтиФиш — пример конфигурации (.env.example)
# Скопируйте в .env и настройте под своё окружение:
#   cp .env.example .env

# ─── Сервер ───────────────────────────────────────────────────────────────────
# Адрес и порт (0.0.0.0 — доступен извне, 127.0.0.1 — только локально)
ANTIPHISH_HOST=0.0.0.0
ANTIPHISH_PORT=8787

# Режим отладки (true/false). В продакшне всегда false!
ANTIPHISH_DEBUG=false

# ─── Безопасность ─────────────────────────────────────────────────────────────
# API-ключ для авторизации запросов расширения.
# Оставьте пустым, чтобы отключить авторизацию (только для разработки).
# Рекомендуется сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
ANTIPHISH_API_KEY=

# Разрешённые CORS-источники (через запятую).
# Для продакшна укажите точный ID вашего расширения:
#   chrome-extension://abcdefghijklmnopqrstuvwxyz123456
ANTIPHISH_CORS_ORIGINS=chrome-extension://*,moz-extension://*,http://localhost:*

# ─── Кэш ──────────────────────────────────────────────────────────────────────
# Время жизни записей в кэше (секунды, по умолчанию 10 минут)
ANTIPHISH_CACHE_TTL=600
# Максимальный размер кэша
ANTIPHISH_CACHE_MAXSIZE=8192

# ─── Ограничение запросов ─────────────────────────────────────────────────────
# Максимальное число запросов с одного IP в минуту
ANTIPHISH_RATE_LIMIT=120

# ─── ML-модель ────────────────────────────────────────────────────────────────
# Порог вероятности фишинга (0.0–1.0).
# Повышение → меньше ложных срабатываний; понижение → выше чувствительность.
ANTIPHISH_THRESHOLD=0.65

# ─── Логирование ──────────────────────────────────────────────────────────────
# Уровень: DEBUG, INFO, WARNING, ERROR, CRITICAL
ANTIPHISH_LOG_LEVEL=INFO
# Путь к файлу логов (по умолчанию — logs/antiphish.log рядом с app.py)
# ANTIPHISH_LOG_FILE=/var/log/antiphish/antiphish.log
