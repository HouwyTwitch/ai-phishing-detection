# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
MANIFEST

# Виртуальные окружения
.venv/
venv/
env/
ENV/
.env
!.env.example

# ── Логи ──────────────────────────────────────────────────────────────────
*.log
logs/
*.log.*

# ── ML-модели (большие бинарные файлы) ────────────────────────────────────
# Храните модели в S3/GCS или Git LFS, не в основном репозитории
server/assets/*.pkl

# ── IDE ───────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Тестовые артефакты ────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml

# ── Docker ────────────────────────────────────────────────────────────────
.dockerignore

# ── Node (если будет npm-сборка для расширения) ───────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
.pnp/

# ── Временные файлы ────────────────────────────────────────────────────────
*.tmp
*.bak
*.swp
~$*
